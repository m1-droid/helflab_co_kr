---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white text-slate-900 border-t border-slate-100 mt-24">
  <div class="container-max py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-1">
        <a href="/" class="text-2xl font-bold text-[#5f0080] tracking-tighter mb-6 block">
          HELFLAB
        </a>
        <p class="text-slate-500 text-sm leading-relaxed mb-6">
          Invisible Commerce Pioneer.<br/>
          가장 정교한 커머스 인프라를 구축합니다.
        </p>
      </div>
      
      <div>
        <h3 class="text-slate-900 font-bold mb-6 text-sm uppercase tracking-wider">Services</h3>
        <ul class="space-y-4 text-slate-500 text-sm">
          <li><a href="/" class="hover:text-[#5f0080] transition-colors">데이터 분석</a></li>
          <li><a href="/partnership" class="hover:text-[#5f0080] transition-colors">AI 물류 솔루션</a></li>
          <li><a href="/partnership" class="hover:text-[#5f0080] transition-colors">글로벌 소싱</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-slate-900 font-bold mb-6 text-sm uppercase tracking-wider">Partnership</h3>
        <ul class="space-y-4 text-slate-500 text-sm">
          <li><a href="/partnership" class="hover:text-[#5f0080] transition-colors">소싱 파트너</a></li>
          <li><a href="https://utongstart.yawncat.co.kr/" target="_blank" class="hover:text-[#5f0080] transition-colors">유통스타트</a></li>
          <li><a href="/partnership" class="hover:text-[#5f0080] transition-colors">글로벌 진출</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-slate-900 font-bold mb-6 text-sm uppercase tracking-wider">Contact</h3>
        <ul class="space-y-4 text-slate-500 text-sm">
          <li>
            <a href="tel:02-6909-5710" class="hover:text-[#5f0080] transition-colors">02-6909-5710</a>
          </li>
          <li>
            <a href="mailto:helflab@helflab.co.kr" class="hover:text-[#5f0080] transition-colors">helflab@helflab.co.kr</a>
          </li>
          <li class="text-xs pt-4 opacity-70 leading-relaxed">
            서울시 성동구 서울숲2길 32-14<br/>
            갤러리아포레 지하1층 B108-1호
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-slate-50 pt-10 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-slate-400 text-xs tracking-tight order-2 md:order-1">&copy; {currentYear} HELFLAB. All rights reserved.</p>
      
      <!-- 패밀리 사이트 드롭다운 -->
      <div class="relative inline-block text-left order-1 md:order-2 w-full md:w-64" id="family-site-container">
        <button 
          id="family-site-btn"
          class="flex items-center justify-between w-full px-5 py-3 bg-[#fbfbfb] border border-slate-100 text-slate-500 text-xs font-bold tracking-widest uppercase hover:border-[#5f0080]/30 transition-all rounded-sm"
        >
          Family Site
          <svg class="w-4 h-4 ml-2 transition-transform duration-300" id="family-site-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        
        <div 
          id="family-site-list"
          class="absolute bottom-full left-0 mb-2 w-full bg-white border border-slate-100 shadow-2xl opacity-0 translate-y-2 pointer-events-none transition-all duration-300 z-50 rounded-sm"
        >
          <ul class="py-2">
            <li>
              <a href="https://utongstart.yawncat.co.kr/" target="_blank" class="block px-5 py-3 text-slate-600 text-[11px] font-bold hover:bg-[#f8f0ff] hover:text-[#5f0080] transition-colors border-b border-slate-50">
                유통스타트
              </a>
            </li>
            <li>
              <a href="https://yawncat.co.kr/" target="_blank" class="block px-5 py-3 text-slate-600 text-[11px] font-bold hover:bg-[#f8f0ff] hover:text-[#5f0080] transition-colors border-b border-slate-50">
                깨어나는돌봄
              </a>
            </li>
            <li class="px-5 py-3 text-slate-400 text-[11px] font-bold border-b border-slate-50 cursor-default">
              (주)한아아이앤티
            </li>
            <li class="px-5 py-3 text-slate-400 text-[11px] font-bold border-b border-slate-50 cursor-default">
              메가엠
            </li>
            <li class="px-5 py-3 text-slate-400 text-[11px] font-bold cursor-default">
              티원글로벌
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  const familyBtn = document.getElementById('family-site-btn');
  const familyList = document.getElementById('family-site-list');
  const familyArrow = document.getElementById('family-site-arrow');
  let isFamilyOpen = false;

  const toggleFamily = (e) => {
    e.stopPropagation();
    isFamilyOpen = !isFamilyOpen;
    
    if (isFamilyOpen) {
      familyList?.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
      familyArrow?.classList.add('rotate-180');
    } else {
      familyList?.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
      familyArrow?.classList.remove('rotate-180');
    }
  };

  familyBtn?.addEventListener('click', toggleFamily);

  document.addEventListener('click', () => {
    if (isFamilyOpen) {
      isFamilyOpen = false;
      familyList?.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
      familyArrow?.classList.remove('rotate-180');
    }
  });
</script>
