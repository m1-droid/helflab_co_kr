---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Secret Admin Portal" currentPath="/admin-write-secret">
  <section class="py-24 bg-[#f7f7f7] min-h-screen">
    <div class="container-max max-w-2xl reveal">
      <div class="mb-12 text-center">
        <span class="text-[#5f0080] text-[10px] font-black tracking-widest uppercase px-3 py-1 border border-[#5f0080]/30 rounded-full mb-4 inline-block">Admin Only</span>
        <h1 class="text-3xl font-black text-slate-900 tracking-tighter uppercase">Content Generator</h1>
        <p class="text-slate-500 text-sm mt-4 font-medium">새로운 블로그 글이나 포트폴리오 마크다운 파일을 생성합니다.</p>
      </div>

      <div class="bg-white p-10 rounded-sm shadow-xl border border-slate-100">
        <form id="generator-form" class="space-y-8">
          <div class="space-y-3">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Target Collection</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer group">
                <input type="radio" name="type" value="blog" checked class="w-4 h-4 accent-[#5f0080]" />
                <span class="text-sm font-bold text-slate-600 group-hover:text-[#5f0080] transition-colors">Blog</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer group">
                <input type="radio" name="type" value="portfolio" class="w-4 h-4 accent-[#5f0080]" />
                <span class="text-sm font-bold text-slate-600 group-hover:text-[#5f0080] transition-colors">Portfolio</span>
              </label>
            </div>
          </div>

          <div class="space-y-4">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Title</label>
            <input type="text" id="title" required placeholder="제목을 입력하세요" class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors font-bold text-slate-900" />
          </div>

          <div class="grid grid-cols-2 gap-8">
            <div class="space-y-4">
              <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Tag / Category</label>
              <input type="text" id="tag" placeholder="Tech, Biz, Growth 등" class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors font-medium text-slate-700" />
            </div>
            <div class="space-y-4">
              <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Icon (Emoji)</label>
              <input type="text" id="icon" placeholder="🚀, 🧠, 📦 등" class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors text-center" />
            </div>
          </div>

          <div class="space-y-4" id="client-field">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Client Name (Portfolio Only)</label>
            <input type="text" id="client" placeholder="고객사명을 입력하세요" class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors font-medium text-slate-700" />
          </div>

          <div class="space-y-4">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Description</label>
            <textarea id="description" rows="2" placeholder="간략한 요약을 작성하세요" class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors resize-none font-medium text-slate-600"></textarea>
          </div>

          <div class="space-y-4">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Main Content (Markdown)</label>
            <textarea id="content" rows="10" placeholder="## 내용을 여기에 작성하세요..." class="w-full border border-slate-100 bg-[#fbfbfb] p-5 focus:outline-none focus:border-[#5f0080] transition-colors resize-y font-mono text-sm"></textarea>
          </div>

          <div class="pt-6">
            <button type="submit" class="w-full bg-[#5f0080] text-white py-5 font-black tracking-widest rounded-sm hover:bg-[#4a0063] transition-all shadow-lg uppercase text-xs">
              Generate & Download File
            </button>
          </div>
        </form>
      </div>
      
      <div class="mt-8 p-6 bg-[#f8f0ff] rounded-sm text-center">
        <p class="text-[11px] text-[#5f0080] font-medium leading-relaxed">
          * 생성된 파일은 다운로드 폴더에서 확인할 수 있습니다.<br/>
          * 다운로드 후 `src/content/{type}/` 폴더에 넣어주세요.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('generator-form') as HTMLFormElement;
  const typeRadios = document.getElementsByName('type');
  const clientField = document.getElementById('client-field');

  // Toggle client field visibility
  typeRadios.forEach(radio => {
    radio.addEventListener('change', (e: any) => {
      if (e.target.value === 'portfolio') {
        clientField?.classList.remove('hidden');
      } else {
        clientField?.classList.add('hidden');
      }
    });
  });

  // Default state for client field
  if ((form.elements.namedItem('type') as any).value === 'blog') {
    clientField?.classList.add('hidden');
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const type = formData.get('type');
    const title = (document.getElementById('title') as HTMLInputElement).value;
    const tag = (document.getElementById('tag') as HTMLInputElement).value;
    const icon = (document.getElementById('icon') as HTMLInputElement).value || '📄';
    const client = (document.getElementById('client') as HTMLInputElement).value;
    const description = (document.getElementById('description') as HTMLTextAreaElement).value;
    const content = (document.getElementById('content') as HTMLTextAreaElement).value;
    const date = new Date().toISOString().split('T')[0];

    // Create Slug (Support Korean)
    const slug = title
      .toLowerCase()
      .trim()
      .replace(/[^\w\s-가-힣]/g, '')
      .replace(/[\s_-]+/g, '-')
      .replace(/^-+|-+$/g, '');

    let mdContent = `---
title: "${title}"
description: "${description}"
pubDate: "${date}"
tag: "${tag}"
icon: "${icon}"
featured: false
`;

    if (type === 'blog') {
      mdContent += `author: "HELFLAB Team"\n`;
    } else {
      mdContent += `client: "${client}"\n`;
    }

    mdContent += `---

${content}
`;

    const blob = new Blob([mdContent], { type: 'text/markdown' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${slug}.md`;
    a.click();
    window.URL.revokeObjectURL(url);

    alert(`파일이 생성되었습니다: ${slug}.md\n\n다운로드 폴더를 확인하신 후 src/content/${type}/ 폴더에 저장해주세요.`);
  });
</script>
