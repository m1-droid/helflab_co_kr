---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<Layout title="보이지 않는 커머스의 설계자 - HELFLAB" currentPath="/">
  <!-- Hero 섹션: 컬리 스타일의 정갈한 화이트/퍼플 배경 -->
  <section class="relative bg-white border-b border-slate-50 pt-24 pb-32 overflow-hidden">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-[#f7f7f7] -skew-x-12 transform origin-top-right"></div>
    
    <div class="container-max relative z-10">
      <div class="max-w-2xl reveal">
        <div class="mb-12">
          <span class="text-[#5f0080] text-xs font-black tracking-[0.2em] uppercase border-b-2 border-[#5f0080] pb-2">
            Invisible Commerce Pioneer
          </span>
        </div>
        
        <h1 class="text-4xl md:text-6xl font-extrabold mb-12 leading-[1.15] tracking-tighter text-slate-900">
          가장 정교한 커머스,<br />
          <span class="text-[#5f0080]">브랜드의 성장 엔진</span>을<br />
          설계합니다.
        </h1>
        
        <p class="text-lg md:text-xl text-slate-500 mb-14 leading-relaxed font-medium">
          25년의 글로벌 소싱 전문성과 독자적인 AI 인프라로<br class="hidden md:block" />
          가장 투명하고 강력한 유통 생태계를 구축합니다.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-5">
          <a href="/partnership" class="btn-primary px-12 py-5 text-lg shadow-lg shadow-[#5f0080]/10">
            파트너십 제안하기
          </a>
          <a href="/about" class="btn-secondary px-12 py-5 text-lg">
            회사 소개 보기
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Value -->
  <section class="py-32 bg-white">
    <div class="container-max">
      <div class="mb-24 text-center reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 tracking-tight">HELFLAB Infrastructure</h2>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          HELFLAB은 브랜드의 신뢰를 배송 합니다.<br/>
          데이터와 기술로 완성하는 가장 프리미엄한 커머스 솔루션.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- 특징 1 -->
        <div class="p-12 bg-[#fbfbfb] border border-slate-50 reveal group hover:bg-white hover:shadow-2xl transition-all duration-500">
          <div class="text-4xl mb-8 group-hover:scale-110 transition-transform">🌍</div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6 tracking-tight">글로벌 소싱 파워</h3>
          <p class="text-slate-500 leading-relaxed mb-10 text-sm">
            전세계 16개국 브랜드 파트너십을 통해 100% 직매입 구조를 유지합니다. 컬리의 깐깐한 기준처럼 정품 신뢰성을 시스템으로 보장합니다.
          </p>
          <div class="text-[#5f0080] font-black text-xs tracking-widest flex items-center gap-2 uppercase">
            Learn More <span class="group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </div>

        <div class="p-12 bg-[#fbfbfb] border border-slate-50 reveal reveal-delay-1 group hover:bg-white hover:shadow-2xl transition-all duration-500">
          <div class="text-4xl mb-8 group-hover:scale-110 transition-transform">🤖</div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6 tracking-tight">AI 물류 시스템</h3>
          <p class="text-slate-500 leading-relaxed mb-10 text-sm">
            3,700만 건의 데이터를 학습한 AI가 최적의 풀필먼트를 실현합니다. 배송의 정밀함을 넘어서는 초정밀 재고 관리를 제공합니다.
          </p>
          <div class="text-[#5f0080] font-black text-xs tracking-widest flex items-center gap-2 uppercase">
            Learn More <span class="group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </div>

        <div class="p-12 bg-[#fbfbfb] border border-slate-50 reveal reveal-delay-2 group hover:bg-white hover:shadow-2xl transition-all duration-500">
          <div class="text-4xl mb-8 group-hover:scale-110 transition-transform">🇨🇳</div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6 tracking-tight">크로스보더 전략</h3>
          <p class="text-slate-500 leading-relaxed mb-10 text-sm">
            중국 20+ 플랫폼 진출과 성공 노하우를 바탕으로, 글로벌 마켓 진출의 모든 복잡한 과정을 HELFLAB이 책임집니다.
          </p>
          <div class="text-[#5f0080] font-black text-xs tracking-widest flex items-center gap-2 uppercase">
            Learn More <span class="group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 최근 소식 블로그 -->
  <section class="bg-[#f7f7f7] py-32 overflow-hidden">
    <div class="container-max">
      <div class="mb-20 reveal">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 tracking-tighter uppercase">Insights</h2>
        <p class="text-lg text-slate-500">커머스 시장의 최신 트렌드와 HELFLAB의 혁신적 성과를 공유합니다.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {latestPosts.map((post, i) => (
          <article class={`bg-white border border-slate-100 reveal reveal-delay-${i} group hover:shadow-xl transition-all`}>
            <a href={`/blog/${post.slug}`}>
              <div class="h-60 bg-[#fbfbfb] flex items-center justify-center text-6xl group-hover:scale-110 transition-transform grayscale opacity-20 group-hover:grayscale-0 group-hover:opacity-100 duration-700">
                {post.data.icon}
              </div>
              <div class="p-10">
                <div class="mb-5">
                  <span class="text-[#5f0080] text-[10px] font-black uppercase tracking-widest px-2 py-0.5 border border-[#5f0080]/20 rounded-sm">
                    {post.data.tag}
                  </span>
                </div>
                <h3 class="text-xl font-bold mb-8 text-slate-900 leading-tight group-hover:text-[#5f0080] transition-colors whitespace-pre-line">
                  {post.data.title}
                </h3>
                <div class="text-slate-400 font-bold text-[11px] tracking-widest flex items-center gap-2 group-hover:text-[#5f0080] transition-colors uppercase">
                  Read insight <span class="text-lg group-hover:translate-x-1 transition-transform">→</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA 섹션: 컬리 스타일의 딥 퍼플 -->
  <section class="bg-[#5f0080] text-white py-32 text-center overflow-hidden relative">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent scale-150"></div>
    <div class="container-max relative z-10 px-6">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-10 tracking-tighter leading-tight reveal">
        검증된 데이터로 증명하는<br class="md:hidden" />
        <span class="opacity-60">확실한 브랜드 성장 파트너십.</span>
      </h2>
      <p class="text-lg md:text-xl text-white/50 mb-16 max-w-2xl mx-auto font-medium reveal reveal-delay-1 leading-relaxed">
        3,700만 건의 누적 데이터가 제시하는 최적의 솔루션으로<br class="hidden md:block"/> 브랜드의 가치를 글로벌 마켓으로 확장하세요.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center reveal reveal-delay-2">
        <a href="/partnership" class="bg-white text-[#5f0080] px-12 py-5 font-black tracking-tight rounded-sm hover:bg-slate-50 transition-all text-lg w-full sm:w-auto">
          파트너십 제안받기
        </a>
        <a href="/contact" class="border border-white/30 text-white px-12 py-5 font-black tracking-tight rounded-sm hover:bg-white/10 transition-all text-lg w-full sm:w-auto">
          상세 상담 신청
        </a>
      </div>
    </div>
  </section>
</Layout>
