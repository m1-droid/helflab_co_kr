---
import Layout from '../layouts/Layout.astro';
---

<Layout title="파트너십" currentPath="/partnership">
  <!-- Partnership Hero: 컬리 스타일의 정갈한 배경 -->
  <section class="bg-[#f7f7f7] text-slate-900 py-24 border-b border-slate-100">
    <div class="container-max reveal text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-8 tracking-tighter text-slate-900 uppercase">Partnership</h1>
      <p class="text-lg md:text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed font-medium">
        글로벌 16개국, 50+ 브랜드가 함께하는<br class="md:hidden" /> 가장 정교한 커머스 네트워크에 참여하세요.
      </p>
    </div>
  </section>

  <section class="py-32 bg-white">
    <div class="container-max">
      <div class="mb-24 text-center reveal">
        <h2 class="text-3xl font-bold text-slate-900 mb-6 tracking-tight">3가지 파트너십 모델</h2>
        <div class="w-12 h-0.5 bg-[#5f0080] mx-auto"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {[
          { title: "소싱 파트너", desc: "글로벌 브랜드 상품을 안정적으로 공급하는 파트너십입니다. 검증된 판매망과 물류를 통해 성장을 지원합니다.", icon: "📦" },
          { title: "유통스타트", desc: "귀사의 브랜드를 다채널로 확장하는 파트너십입니다. AI 물류망을 통해 가파른 성장을 실현합니다.", icon: "🚀", externalLink: "https://utongstart.yawncat.co.kr/" },
          { title: "Global 파트너", desc: "해외 시장 진출을 목표로 하는 브랜드를 위한 풀 서비스입니다. 현지화부터 배송까지 모두 지원합니다.", icon: "🌍" }
        ].map((model, i) => (
          <div class={`border border-slate-100 bg-[#fbfbfb] p-12 reveal reveal-delay-${i} hover:shadow-2xl transition-all group flex flex-col`}>
            <div class="text-4xl mb-8 group-hover:scale-110 transition-transform">{model.icon}</div>
            <h3 class="text-2xl font-bold text-slate-900 mb-6 tracking-tight">{model.title}</h3>
            <p class="text-slate-500 mb-12 leading-relaxed text-sm flex-1">
              {model.desc}
            </p>
            <a href={model.externalLink || "#contact-form"} target={model.externalLink ? "_blank" : undefined} class="btn-primary w-full text-sm font-black py-4 rounded-sm tracking-widest uppercase">
              {model.title === "유통스타트" ? "Visit UtongStart" : "Apply Now"}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 파트너 혜택: 스트라이프 레이아웃 -->
  <section class="bg-[#fcfcfc] py-32 border-y border-slate-50">
    <div class="container-max">
      <h2 class="text-3xl md:text-4xl font-bold mb-20 text-center text-slate-900 reveal tracking-tight">Core Partnership Benefits</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {[
          { title: "데이터 기반 의사결정", desc: "3,700만 건의 거래 데이터와 AI 분석으로 시장 트렌드와 가격 전략까지 완벽하게 가이드합니다.", icon: "📊" },
          { title: "글로벌 확장 인프라", desc: "한국을 넘어 중국, 동남아, 글로벌 시장으로 즉시 진출 가능한 통합 시스템을 제공합니다.", icon: "🌐" },
          { title: "운영 자동화 (5 Systems)", desc: "ERP, WMS, MMS 등 5가지 핵심 시스템으로 모든 유통 과정을 자동화하고 최적화합니다.", icon: "⚙️" },
          { title: "전담 전문가 그룹", desc: "각 파트너마다 전담 전문 인력을 배치하여 물류부터 마케팅까지 전방위 지원을 보장합니다.", icon: "🤝" }
        ].map((benefit, i) => (
          <div class={`p-10 bg-white border border-slate-50 reveal reveal-delay-${i % 2} hover:border-[#5f0080]/30 transition-colors`}>
            <div class="text-3xl mb-6">{benefit.icon}</div>
            <h3 class="text-xl font-bold text-slate-900 mb-4 tracking-tight">{benefit.title}</h3>
            <p class="text-slate-500 leading-relaxed text-sm font-medium">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 성공 사례: 심플 피드백 카드 -->
  <section class="py-32 bg-white">
    <div class="container-max">
      <h2 class="text-3xl md:text-4xl font-bold mb-20 text-center text-slate-900 reveal tracking-tight">Success Stories</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {[
          { brand: "K-Fashion 브랜드 A", title: "중국 진출 6개월 만에\n월매출 300만 위안 달성", desc: "플랫폼 최적화 전략으로 연간 목표를 240% 초과 달성하며 성공적인 안착" },
          { brand: "Life-style 브랜드 B", title: "물류 처리량 600% 확대\n오배송율 0.01% 미만", desc: "HELFLAB AI 물류 연동 후 폭발적인 주문량 증가에도 안정적인 운영 유지" },
          { brand: "Cosmetic 브랜드 C", title: "글로벌 7개국 동시 런칭\n매출 전년비 500% 성장", desc: "통합 인프라를 활용하여 재고 리스크 없이 글로벌 시장 점유율 확보" }
        ].map((story, i) => (
          <div class={`p-10 bg-[#fbfbfb] border border-slate-50 reveal reveal-delay-${i} hover:shadow-md transition-all`}>
            <p class="text-[10px] font-black text-[#5f0080] uppercase tracking-widest mb-4 italic">{story.brand}</p>
            <h4 class="text-xl font-bold text-slate-900 mb-6 tracking-tight leading-snug whitespace-pre-line">{story.title}</h4>
            <div class="w-8 h-0.5 bg-slate-200 mb-6"></div>
            <p class="text-slate-500 text-xs leading-relaxed font-medium">{story.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 빠른 연락처: 바 형태 -->
  <section class="bg-white py-12 border-y border-slate-100">
    <div class="container-max">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center text-sm reveal">
        <div class="flex flex-col gap-2">
          <span class="text-[#5f0080] font-black uppercase tracking-widest text-[10px]">Office Address</span>
          <p class="text-slate-600 font-bold">서울시 성동구 서울숲2길 32-14 갤러리아포레 B108-1호</p>
        </div>
        <div class="flex flex-col gap-2 border-x border-slate-50">
          <span class="text-[#5f0080] font-black uppercase tracking-widest text-[10px]">Official Email</span>
          <p class="text-slate-600 font-bold underline underline-offset-4 decoration-[#5f0080]/30 hover:text-[#5f0080] transition-colors">
            <a href="mailto:helflab@helflab.co.kr">helflab@helflab.co.kr</a>
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <span class="text-[#5f0080] font-black uppercase tracking-widest text-[10px]">Hotline Support</span>
          <p class="text-slate-600 font-bold">02-6909-5710</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 파트너십 문의 폼: 정제된 미니멀 폼 -->
  <section id="contact-form" class="py-32 bg-white">
    <div class="container-max max-w-2xl">
      <div class="mb-20 text-center reveal">
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-6 tracking-tighter">Partner Application</h2>
        <p class="text-slate-500 font-medium leading-relaxed">입점 정보를 남겨주시면 분야별 전담 파트너가<br class="md:hidden"/> 24시간 이내에 연락드리겠습니다.</p>
      </div>
      
      <form method="POST" action="/api/send-email" class="reveal reveal-delay-1 space-y-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div class="space-y-4">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Company Name</label>
            <input type="text" name="company" placeholder="회사명을 입력해주세요" required class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors placeholder:text-slate-300 font-medium" />
          </div>
          <div class="space-y-4">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Contact Name</label>
            <input type="text" name="name" placeholder="담당자 성함을 입력해주세요" required class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors placeholder:text-slate-300 font-medium" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div class="space-y-4">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Email Address</label>
            <input type="email" name="email" placeholder="example@company.com" required class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors placeholder:text-slate-300 font-medium" />
          </div>
          <div class="space-y-4">
            <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Phone Number</label>
            <input type="tel" name="phone" placeholder="전화번호를 입력해주세요" required class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors placeholder:text-slate-300 font-medium" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
           <div class="space-y-4">
              <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Partnership Type</label>
              <select name="partnershipType" required class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] bg-white transition-colors font-medium">
                <option value="">선택해주세요</option>
                <option>소싱 파트너</option>
                <option>유통스타트</option>
                <option>크로스보더 파트너</option>
                <option>기타</option>
              </select>
           </div>
           <div class="space-y-4">
              <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Product Category</label>
              <select name="productCategory" required class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] bg-white transition-colors font-medium">
                <option value="">선택해주세요</option>
                <option>패션 / 코스메틱</option>
                <option>라이프스타일 / 리빙</option>
                <option>디지털 / 가전</option>
                <option>식품 / 이너뷰티</option>
                <option>기타</option>
              </select>
           </div>
        </div>

        <div class="space-y-4">
          <label class="block text-[11px] font-black text-[#5f0080] uppercase tracking-widest">Inquiry Message</label>
          <textarea name="message" rows="5" placeholder="브랜드 소개 및 파트너십 문의 내용을 자유롭게 적어주세요." required class="w-full border-b border-slate-200 py-3 focus:outline-none focus:border-[#5f0080] transition-colors placeholder:text-slate-300 resize-none font-medium"></textarea>
        </div>

        <div class="pt-10">
          <button type="submit" class="w-full bg-[#5f0080] text-white py-6 font-black tracking-[0.2em] rounded-sm hover:bg-[#4a0063] transition-all uppercase text-sm shadow-xl shadow-[#5f0080]/10">
            Submit Application
          </button>
        </div>
      </form>
    </div>
  </section>
</Layout>
