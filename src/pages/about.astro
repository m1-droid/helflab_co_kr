---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HELFLAB - 브랜드 성장 파트너" currentPath="/about">
  <!-- 소개 히어로: 컬리 스타일의 정갈한 배경 -->
  <section class="bg-[#f7f7f7] py-24 border-b border-slate-100 overflow-hidden">
    <div class="container-max reveal text-center">
      <div class="mb-8">
        <span class="text-[#5f0080] text-sm font-bold tracking-widest px-4 py-1 border border-[#5f0080] rounded-full">
          ABOUT HELFLAB
        </span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-8 tracking-tighter text-slate-900 leading-[1.2]">
        브랜드 성장의<br class="md:hidden" />
        <span class="text-[#5f0080]">가장 정교한 엔진</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed">
        AI 기반 데이터 분석과 글로벌 네트워크를 결합하여<br class="hidden md:block" />
        차세대 커머스 인프라를 혁신하는 브랜드 성장 파트너입니다.
      </p>
    </div>
  </section>

  <!-- 미션 / 비전 / 가치 -->
  <section class="py-24 bg-white">
    <div class="container-max">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- 미션 -->
        <div class="p-10 bg-[#fbfbfb] border border-slate-50 reveal hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold text-[#5f0080] mb-6 tracking-tight">🎯 MISSION</h3>
          <p class="text-slate-600 leading-relaxed font-medium">
            신뢰할 수 있는 인프라와 전략적 실행력을 통해 차세대 커머스의 표준을 제시합니다.
          </p>
        </div>
        
        <!-- 비전 -->
        <div class="p-10 bg-[#fbfbfb] border border-slate-50 reveal reveal-delay-1 hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold text-[#5f0080] mb-6 tracking-tight">🌟 VISION</h3>
          <p class="text-slate-600 leading-relaxed font-medium">
            AI 기반 데이터 분석과 글로벌 네트워크를 활용하여 국경 없는 쇼핑 경험의 진화를 선도합니다.
          </p>
        </div>
        
        <!-- 핵심가치 -->
        <div class="p-10 bg-[#fbfbfb] border border-slate-50 reveal reveal-delay-2 hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold text-[#5f0080] mb-6 tracking-tight">⭐ CORE VALUE</h3>
          <ul class="space-y-4 text-slate-600 font-medium">
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#5f0080]"></span>
              Integrity – 데이터 기반의 신뢰
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#5f0080]"></span>
              Agility – AI 시스템 전제 속도
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#5f0080]"></span>
              Partnership – 동반 성장의 가치
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 핵심 가치 상세 -->
  <section class="bg-[#fcfcfc] py-24 border-y border-slate-50">
    <div class="container-max">
      <h2 class="text-3xl font-bold mb-16 text-center text-slate-900 reveal">HELFLAB Core Value</h2>
      
      <div class="space-y-20">
        <!-- Integrity -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center reveal">
          <div class="order-2 md:order-1">
            <div class="text-[#5f0080] font-black italic text-6xl opacity-10 mb-2">01</div>
            <h3 class="text-3xl font-bold text-slate-900 mb-6">Integrity</h3>
            <h4 class="text-lg font-semibold text-[#5f0080] mb-4">데이터로 증명하는 100% 신뢰</h4>
            <p class="text-slate-500 leading-relaxed">
              정품 유통과 투명한 거래 데이터를 기반으로 브랜드와 소비자 모두에게 신뢰 가능한 커머스 생태계를 구축합니다. 25년간의 무사고 레퍼런스가 헬프랩의 진정성을 대변합니다.
            </p>
          </div>
          <div class="order-1 md:order-2 bg-white border border-slate-100 h-80 rounded-sm flex items-center justify-center shadow-sm">
            <span class="text-8xl grayscale opacity-20">🛡️</span>
          </div>
        </div>
        
        <!-- Agility -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center reveal">
          <div class="bg-white border border-slate-100 h-80 rounded-sm flex items-center justify-center shadow-sm">
            <span class="text-8xl grayscale opacity-20">⚡</span>
          </div>
          <div>
            <div class="text-[#5f0080] font-black italic text-6xl opacity-10 mb-2">02</div>
            <h3 class="text-3xl font-bold text-slate-900 mb-6">Agility</h3>
            <h4 class="text-lg font-semibold text-[#5f0080] mb-4">AI로 구현하는 초격차 실행 속도</h4>
            <p class="text-slate-500 leading-relaxed">
              시장 트렌드와 판매 데이터를 AI로 실시간 분석하여 데이터 기반의 의사결정과 빠른 실행으로 경쟁 우위를 만듭니다. 우리는 사람의 직관이 아닌 시스템의 정밀함으로 움직입니다.
            </p>
          </div>
        </div>
        
        <!-- Partnership -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center reveal">
          <div>
            <div class="text-[#5f0080] font-black italic text-6xl opacity-10 mb-2">03</div>
            <h3 class="text-3xl font-bold text-slate-900 mb-6">Partnership</h3>
            <h4 class="text-lg font-semibold text-[#5f0080] mb-4">지속 가능한 성장의 가치 공유</h4>
            <p class="text-slate-500 leading-relaxed">
              단기적 이익이 아닌, 브랜드의 장기적 성장을 위한 데이터 인사이트를 투명하게 공유합니다. 헬프랩의 모든 시스템은 파트너의 성공을 위해 최적화되어 있습니다.
            </p>
          </div>
          <div class="bg-white border border-slate-100 h-80 rounded-sm flex items-center justify-center shadow-sm">
            <span class="text-8xl grayscale opacity-20">🤝</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 리더십 & AI 에이전트: 모바일 우선의 정갈한 레이아웃 -->
  <section class="py-24 bg-white">
    <div class="container-max">
      <div class="text-center mb-20 reveal">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">Our Unique Team</h2>
        <p class="text-slate-500">25년의 노하우와 커스텀 AI 에이전트가 완벽한 팀워크를 이룹니다.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-24">
        <!-- Captain -->
        <div class="p-10 bg-[#fbfbfb] border border-slate-50 reveal hover:shadow-md transition-all">
          <h4 class="text-[#5f0080] font-bold text-sm mb-4 uppercase tracking-widest">Captain / CEO</h4>
          <h3 class="text-3xl font-bold text-slate-900 mb-6 tracking-tighter">유종현</h3>
          <p class="text-slate-600 leading-relaxed mb-8">
            25년 경력의 마케팅 전문가이자 AI 에이전트 조직의 설계자입니다. 브랜드 론칭부터 글로벌 유통까지 실전 경험을 보유하고 있으며, 미래형 기업 운영 모델을 직접 구축하고 있습니다.
          </p>
          <div class="text-xs text-slate-400 font-bold border-t border-slate-100 pt-6">
            Strategy / Budget / Go-No 판단
          </div>
        </div>

        <!-- CTO -->
        <div class="p-10 bg-[#fbfbfb] border border-slate-50 reveal reveal-delay-1 hover:shadow-md transition-all">
          <h4 class="text-[#5f0080] font-bold text-sm mb-4 uppercase tracking-widest">CTO / Architect</h4>
          <h3 class="text-3xl font-bold text-slate-900 mb-6 tracking-tighter">족장</h3>
          <p class="text-slate-600 leading-relaxed mb-8">
            AI 에이전트 조직의 전체 시스템을 설계하는 기술 총괄입니다. 프롬프트 엔지니어링과 워크플로우 아키텍처를 담당하며, 사람이 아닌 '시스템'이 일하는 문화를 기술로 완성합니다.
          </p>
          <div class="text-xs text-slate-400 font-bold border-t border-slate-100 pt-6">
            AI System / Workflow / Tech Innovation
          </div>
        </div>
      </div>

      <!-- AI 에이전트 팀 (모바일 가독성 중심) -->
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4 reveal reveal-delay-2">
        {[
          { name: '루미', role: 'Staff', icon: '📋' },
          { name: '셀라', role: 'Sales', icon: '💰' },
          { name: '벨리', role: 'Analyst', icon: '📈' },
          { name: '채니', role: 'Ops', icon: '⚙️' },
          { name: '크리', role: 'Creator', icon: '🎨' },
          { name: '퍼포', role: 'Mkt', icon: '🚀' },
          { name: '데브', role: 'Dev', icon: '💻' }
        ].map((agent) => (
          <div class="bg-[#fbfbfb] border border-slate-50 p-6 text-center hover:border-[#5f0080] transition-colors cursor-default group">
            <div class="text-2xl mb-4 group-hover:scale-110 transition-transform">{agent.icon}</div>
            <div class="font-bold text-slate-900 text-sm mb-1">{agent.name}</div>
            <div class="text-[10px] text-[#5f0080] font-black uppercase tracking-tighter">{agent.role}</div>
          </div>
        ))}
      </div>
      
      <div class="mt-8 text-center reveal reveal-delay-3 px-6 py-4 bg-[#f8f0ff] rounded-sm inline-block mx-auto">
        <p class="text-[13px] text-[#5f0080] font-medium leading-relaxed">
          * 헬프랩의 모든 AI 에이전트는 독립적인 페르소나와 최적화된 프롬프트를 가지고 실제 업무를 수행합니다.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA 푸터 히어로 -->
  <section class="bg-[#5f0080] text-white py-24 text-center overflow-hidden relative">
    <div class="absolute top-0 left-0 w-full h-full opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
    <div class="container-max relative z-10 px-6">
      <h2 class="text-3xl md:text-5xl font-bold mb-10 tracking-tighter leading-tight reveal">
        귀사 브랜드의 새로운 성장 엔진,<br class="md:hidden" />
        <span class="opacity-70">헬프랩과 함께 설계하세요.</span>
      </h2>
      <div class="flex flex-col md:flex-row gap-4 justify-center items-center reveal reveal-delay-1">
        <a href="/partnership" class="bg-white text-[#5f0080] px-12 py-5 font-bold tracking-tight rounded-sm hover:bg-slate-50 transition-all w-full md:w-auto">
          파트너십 문의하기
        </a>
        <a href="/contact" class="border border-white/30 px-12 py-5 font-bold tracking-tight rounded-sm hover:bg-white/10 transition-all w-full md:w-auto">
           찾아오시는 길
        </a>
      </div>
    </div>
  </section>
</Layout>
