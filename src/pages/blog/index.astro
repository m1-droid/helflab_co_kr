---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featuredPost = sortedPosts.find(post => post.data.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter(post => post.slug !== featuredPost.slug);
---

<Layout title="블로그" currentPath="/blog">
  <!-- 블로그 히어로 -->
  <section class="bg-[#f7f7f7] py-20 border-b border-slate-100">
    <div class="container-max reveal text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 tracking-tighter uppercase">Insight & Tech</h1>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto font-medium">커머스의 미래를 그리는 HelfLab의<br class="md:hidden" /> 기술과 비즈니스 인사이트를 만나보세요.</p>
    </div>
  </section>

  <!-- 최신 포스트 -->
  <section class="py-24">
    <div class="container-max">
      <!-- 대표 포스트 (Featured) -->
      {featuredPost && (
        <article class="mb-24 reveal">
          <a href={`/blog/${featuredPost.slug}`} class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center bg-[#fbfbfb] border border-slate-50 p-6 md:p-10 group cursor-pointer hover:shadow-xl transition-all">
            <div class="aspect-video bg-slate-100 overflow-hidden rounded-sm flex items-center justify-center text-8xl grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105">
              {featuredPost.data.icon}
            </div>
            <div>
              <div class="flex items-center gap-3 mb-6">
                <span class="bg-[#5f0080] text-white text-[10px] font-black px-3 py-1 rounded-sm uppercase tracking-widest">Featured</span>
                <span class="text-slate-400 text-xs font-medium italic">
                  {featuredPost.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\. /g, '. ').replace(/\.$/, '')}
                </span>
              </div>
              <h2 class="text-3xl font-bold text-slate-900 mb-6 tracking-tighter leading-tight group-hover:text-[#5f0080] transition-colors">{featuredPost.data.title}</h2>
              <p class="text-slate-500 mb-10 leading-relaxed line-clamp-3 font-medium">{featuredPost.data.description}</p>
              <div class="inline-flex items-center gap-2 text-[#5f0080] font-bold text-sm hover:translate-x-1 transition-transform">
                KEEP READING <span class="text-lg">→</span>
              </div>
            </div>
          </a>
        </article>
      )}

      <!-- 포스트 그리드 -->
      <div class="flex items-center justify-between mb-12 reveal">
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Recent Insights</h2>
        <div class="hidden md:flex gap-4">
           {['All', 'Tech', 'Biz', 'Culture'].map(t => (
             <span class="text-xs font-bold text-slate-400 hover:text-[#5f0080] cursor-pointer transition-colors px-3 py-1">{t}</span>
           ))}
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 mb-24">
        {recentPosts.map((post, i) => (
          <article class={`reveal reveal-delay-${i % 3} bg-[#fbfbfb] border border-slate-50 group hover:shadow-lg transition-all`}>
            <a href={`/blog/${post.slug}`}>
              <div class="aspect-video bg-slate-100 mb-6 flex items-center justify-center text-5xl grayscale opacity-30 group-hover:grayscale-0 group-hover:opacity-100 transition-all border-b border-slate-50">
                {post.data.icon}
              </div>
              <div class="p-8 pt-2">
                <div class="flex items-center justify-between mb-4">
                  <span class="text-[10px] font-black text-[#5f0080] uppercase tracking-widest">{post.data.tag}</span>
                  <span class="text-[10px] text-slate-400 font-medium italic">
                    {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\. /g, '. ').replace(/\.$/, '')}
                  </span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-6 tracking-tight line-clamp-2 leading-snug group-hover:text-[#5f0080] transition-colors">{post.data.title}</h3>
                <div class="inline-block text-[11px] font-black text-slate-400 group-hover:text-[#5f0080] transition-colors border-b-2 border-slate-100 group-hover:border-[#5f0080]/30 pb-1">
                  READ MORE
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 뉴스레터: 컬리 스타일의 딥퍼플 -->
  <section class="bg-[#5f0080] text-white py-24">
    <div class="container-max reveal text-center px-6">
      <h2 class="text-3xl md:text-4xl font-black mb-6 tracking-tighter">Stay Connected</h2>
      <p class="text-white/60 text-lg mb-12 max-w-xl mx-auto">헬프랩이 전하는 최신 이커머스 트렌드와 기술 인사이트를 이메일로 받아보세요.</p>
      <div class="max-w-xl mx-auto flex flex-col md:flex-row gap-4">
        <input type="email" placeholder="이메일 주소를 입력해주세요" class="flex-1 bg-white/10 border border-white/20 rounded-sm px-6 py-4 focus:outline-none focus:bg-white/20 transition-all placeholder:text-white/40" />
        <button class="bg-white text-[#5f0080] font-black px-10 py-4 rounded-sm hover:bg-slate-50 transition-all text-sm tracking-widest uppercase">
          Subscribe
        </button>
      </div>
      <p class="mt-6 text-[11px] text-white/30">본 신청 시 헬프랩의 개인정보 처리방침에 동의하는 것으로 간주됩니다.</p>
    </div>
  </section>
</Layout>
